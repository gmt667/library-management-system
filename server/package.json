{
  "name": "server",
  "version": "1.0.0",
  "description": "Library Hub Pro Backend API",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
